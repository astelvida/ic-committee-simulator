# Adversarial IC — environment configuration
#
# The committee is powered by Google Gemini, called server-side from
# app/api/model/route.ts so the key is never exposed to the browser.
#
# Copy this file to `.env.local` and fill in your key:
#   cp .env.example .env.local
#
# Get a key at https://aistudio.google.com/apikey
#
# Without a key the app still runs — it falls back to the built-in scripted
# committee (no live model), so you can demo the full flow offline.

GEMINI_API_KEY=

# Optional. Defaults to gemini-flash-latest (rolling alias — always the current
# flash model, so it won't 404 when a pinned version is retired).
# Pin a version if you prefer, e.g. gemini-3.5-flash or gemini-3.5-pro.
GEMINI_MODEL=gemini-flash-latest

# Optional. Set to "true" to let the committee ground answers with Google
# Search (relaxes the memo-only, no-fabricated-numbers guarantee — enable
# consciously). Defaults to off.
IC_USE_SEARCH=false
